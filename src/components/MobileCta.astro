---
import { site, contactHref } from '../data/site';
---

<div
  class="mobile-cta"
  style="position:fixed;bottom:0;left:0;right:0;z-index:46;gap:1px;background:rgba(238,241,244,.12);border-top:1px solid rgba(238,241,244,.12)"
>
  <a
    href={site.phoneHref}
    style="flex:1;text-align:center;background:#1b1f24;color:#eef1f4;font:800 15px 'Barlow Condensed',sans-serif;letter-spacing:.08em;text-transform:uppercase;padding:16px"
  >
    Hringja
  </a>
  <a
    href={contactHref}
    style="flex:1;text-align:center;background:#3778c2;color:#fff;font:800 15px 'Barlow Condensed',sans-serif;letter-spacing:.08em;text-transform:uppercase;padding:16px"
  >
    Fáðu tilboð
  </a>
</div>
