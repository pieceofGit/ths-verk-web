---
import { site, closingCta, contactHref } from '../data/site';
---

<div data-reveal style="background:#3778c2;color:#fff">
  <div
    class="wrap"
    style="max-width:1180px;margin:0 auto;padding:64px 40px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:28px"
  >
    <div>
      <div style="font:700 13px 'Space Mono',monospace;letter-spacing:.24em;color:#cfe0f4;margin-bottom:12px">
        {closingCta.eyebrow}
      </div>
      <div style="font:900 clamp(32px,5vw,52px)/1 'Archivo',sans-serif">{closingCta.heading}</div>
      <div style="font:500 17px 'Barlow Condensed',sans-serif;letter-spacing:.08em;margin-top:12px;text-transform:uppercase;color:#dbe8f6">
        {closingCta.sub}
      </div>
    </div>
    <div style="display:flex;gap:14px;flex-wrap:wrap">
      <a
        href={contactHref}
        style="background:#15181c;color:#fff;font:800 18px 'Archivo',sans-serif;padding:17px 30px;border-radius:3px"
      >
        Fáðu tilboð →
      </a>
      <a
        href={site.phoneHref}
        style="background:rgba(255,255,255,.16);color:#fff;font:800 18px 'Archivo',sans-serif;padding:17px 30px;border-radius:3px"
      >
        Hringja
      </a>
    </div>
  </div>
</div>
