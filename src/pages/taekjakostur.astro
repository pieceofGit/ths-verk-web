---
import Base from '../layouts/Base.astro';
import { reader, resolveImg } from '../lib/content';
import { eyebrows, equipmentTabs } from '../data/site';

const equipment = await reader.singletons.equipment.read();
if (!equipment) throw new Error('Vantar efni fyrir "Tækjakostur" (src/content/equipment)');

const placeholderTile =
  "height:220px;background:#20242a;display:flex;align-items:center;justify-content:center;font:700 12px 'Space Mono',monospace;color:#565d66;letter-spacing:.1em;background-image:repeating-linear-gradient(45deg,rgba(55,120,194,.08) 0 2px,transparent 2px 20px)";
---

<Base title="Tækjakostur — Þ.S. Verktakar ehf.">
  <div class="wrap wrap-top" style="max-width:1180px;margin:0 auto;padding:150px 40px 40px">
    <div data-reveal style="font:700 13px 'Space Mono',monospace;color:#3778c2;letter-spacing:.24em;margin-bottom:14px">
      {eyebrows.equipment}
    </div>
    <h1 data-reveal style="margin:0 0 32px;font:900 clamp(44px,7vw,88px)/0.95 'Archivo',sans-serif">
      Búnaður fyrir hvert verk
    </h1>

    <!-- tab bar -->
    <div data-reveal style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:40px">
      {
        equipmentTabs.map((t) => (
          <button
            data-taeki={t.key}
            style="font:700 13px 'Barlow Condensed',sans-serif;letter-spacing:.12em;text-transform:uppercase;padding:12px 22px;border:1px solid rgba(238,241,244,.2);background:transparent;color:#eef1f4;border-radius:3px;cursor:pointer"
          >
            {t.label}
          </button>
        ))
      }
    </div>

    <!-- GRÖFUR -->
    <div data-taeki-panel="grofur">
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px">
        {
          equipment.grofur.map((g) => (
            <div
              class="fleet-card"
              data-reveal
              style="border:1px solid rgba(238,241,244,.12);border-radius:5px;overflow:hidden"
            >
              {g.image ? (
                <div style={`height:220px;background:url('${resolveImg(g.image)}') center/cover no-repeat`} />
              ) : (
                <div style={placeholderTile}>[ mynd væntanleg ]</div>
              )}
              <div style="padding:22px">
                <div style="font:800 22px 'Archivo',sans-serif">{g.title}</div>
                {g.sub && (
                  <div style="font:400 15px 'IBM Plex Sans',sans-serif;color:#9aa2ab;margin-top:4px">{g.sub}</div>
                )}
                {g.stats && g.stats.length > 0 && (
                  <div style="display:flex;gap:24px;margin-top:16px;padding-top:16px;border-top:1px solid rgba(238,241,244,.1)">
                    {g.stats.map((st) => (
                      <div>
                        <div style="font:800 20px 'Archivo',sans-serif;color:#6fa0dc">{st.value}</div>
                        <div style="font:400 12px 'IBM Plex Sans',sans-serif;color:#7d848d">{st.label}</div>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- VÖRUBÍLAR -->
    <div data-taeki-panel="vorubilar" style="display:none">
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:20px">
        {
          equipment.vorubilar.map((v) => (
            <div
              class="fleet-card"
              data-reveal
              style="border:1px solid rgba(238,241,244,.12);border-radius:5px;overflow:hidden"
            >
              {v.image ? (
                <div style={`height:280px;background:url('${resolveImg(v.image)}') center/cover no-repeat`} />
              ) : (
                <div style={`${placeholderTile};height:280px`}>[ mynd væntanleg ]</div>
              )}
              <div style="padding:24px">
                <div style="font:800 24px 'Archivo',sans-serif">{v.title}</div>
                {v.sub && (
                  <div style="font:400 15px 'IBM Plex Sans',sans-serif;color:#9aa2ab;margin-top:4px">{v.sub}</div>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- BÚKOLLUR -->
    <div data-taeki-panel="bukollur" style="display:none">
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:20px">
        {
          equipment.bukollur.map((b) => (
            <div
              class="fleet-card"
              data-reveal
              style="border:1px solid rgba(238,241,244,.12);border-radius:5px;overflow:hidden"
            >
              {b.image ? (
                <div style={`height:280px;background:url('${resolveImg(b.image)}') center/cover no-repeat`} />
              ) : (
                <div style={`${placeholderTile};height:280px`}>[ mynd væntanleg ]</div>
              )}
              <div style="padding:24px">
                <div style="font:800 24px 'Archivo',sans-serif">{b.title}</div>
                {b.sub && (
                  <div style="font:400 15px 'IBM Plex Sans',sans-serif;color:#9aa2ab;margin-top:4px">{b.sub}</div>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- ÖNNUR TÆKI -->
    <div data-taeki-panel="onnur" style="display:none">
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px">
        {
          equipment.onnur.map((o) => (
            <div
              class="fleet-card"
              data-reveal
              style="border:1px solid rgba(238,241,244,.12);border-radius:5px;overflow:hidden"
            >
              {o.image ? (
                <div style={`height:220px;background:url('${resolveImg(o.image)}') center/cover no-repeat`} />
              ) : (
                <div style={placeholderTile}>[ mynd væntanleg ]</div>
              )}
              <div style="padding:22px">
                <div style="font:800 22px 'Archivo',sans-serif">{o.title}</div>
                {o.sub && (
                  <div style="font:400 15px 'IBM Plex Sans',sans-serif;color:#9aa2ab;margin-top:6px">{o.sub}</div>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</Base>
