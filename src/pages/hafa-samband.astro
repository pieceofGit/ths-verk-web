---
import Base from '../layouts/Base.astro';
import { reader, telHref, mapEmbed } from '../lib/content';
import { eyebrows } from '../data/site';

const contact = await reader.singletons.contact.read();
const settings = await reader.singletons.settings.read();
if (!contact || !settings) throw new Error('Vantar efni fyrir "Hafa samband"');

const phone = settings.phone ?? '';
const email = settings.email ?? '';
const address = settings.address ?? '';
const facebook = settings.facebook ?? '#';

const labelStyle =
  "font:600 12px 'Barlow Condensed',sans-serif;letter-spacing:.12em;text-transform:uppercase;color:#9aa2ab";
const inputStyle =
  "width:100%;background:#15181c;border:1px solid rgba(238,241,244,.14);border-radius:4px;padding:12px 14px;color:#eef1f4;font:400 15px 'IBM Plex Sans',sans-serif;margin-top:6px";
---

<Base title="Hafa samband — Fáðu tilboð | Þ.S. Verktakar ehf." showClosingCta={false}>
  <div class="wrap wrap-top" style="max-width:1180px;margin:0 auto;padding:150px 40px 40px">
    <div data-reveal style="font:700 13px 'Space Mono',monospace;color:#3778c2;letter-spacing:.24em;margin-bottom:14px">
      {eyebrows.contact}
    </div>
    <h1 data-reveal style="margin:0 0 40px;font:900 clamp(44px,7vw,88px)/0.95 'Archivo',sans-serif">
      Fáðu tilboð
    </h1>

    <div class="qform" style="display:grid;grid-template-columns:1.15fr .85fr;gap:40px;align-items:start">
      <!-- FORM -->
      <div data-reveal style="background:#1b1f24;border:1px solid rgba(238,241,244,.12);border-radius:6px;padding:34px 32px">
        <div style="font:800 27px 'Archivo',sans-serif">{contact.formTitle}</div>
        <div style="font:400 15px/1.55 'IBM Plex Sans',sans-serif;color:#9aa2ab;margin:6px 0 26px">
          {contact.formSub}
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
          <label style="display:block">
            <span style={labelStyle}>Nafn *</span>
            <input id="q-nafn" type="text" style={inputStyle} />
          </label>
          <label style="display:block">
            <span style={labelStyle}>Sími</span>
            <input id="q-simi" type="tel" style={inputStyle} />
          </label>
        </div>

        <label style="display:block;margin-top:16px">
          <span style={labelStyle}>Netfang</span>
          <input id="q-netfang" type="email" style={inputStyle} />
        </label>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:16px">
          <label style="display:block">
            <span style={labelStyle}>Tegund verks</span>
            <select id="q-tegund" style={inputStyle}>
              {contact.workTypes.map((w) => <option>{w}</option>)}
            </select>
          </label>
          <label style="display:block">
            <span style={labelStyle}>Staðsetning</span>
            <input id="q-stadur" type="text" placeholder="t.d. Egilsstaðir" style={inputStyle} />
          </label>
        </div>

        <label style="display:block;margin-top:16px">
          <span style={labelStyle}>Lýsing á verki</span>
          <textarea id="q-lysing" rows="4" style={`${inputStyle};resize:vertical`}></textarea>
        </label>

        <button
          data-quote-submit
          data-quote-email={email}
          style="margin-top:22px;width:100%;background:#3778c2;color:#fff;border:0;border-radius:4px;padding:16px;font:800 16px 'Archivo',sans-serif;cursor:pointer"
        >
          Senda fyrirspurn →
        </button>
        <div id="q-status" style="font:600 14px 'IBM Plex Sans',sans-serif;margin-top:14px;min-height:18px"></div>
        <div style="display:flex;align-items:center;gap:8px;margin-top:6px;font:400 13px 'IBM Plex Sans',sans-serif;color:#7d848d">
          {contact.reassurance}
        </div>
      </div>

      <!-- CONTACT -->
      <div data-reveal style="display:flex;flex-direction:column;gap:16px">
        <a href={telHref(phone)} style="display:block;background:#1b1f24;border:1px solid rgba(238,241,244,.12);border-radius:5px;padding:22px 24px;color:#eef1f4">
          <div style="font:700 12px 'Space Mono',monospace;color:#3778c2;letter-spacing:.16em">SÍMI</div>
          <div style="font:800 26px 'Archivo',sans-serif;margin-top:6px">{phone}</div>
        </a>
        <a href={`mailto:${email}`} style="display:block;background:#1b1f24;border:1px solid rgba(238,241,244,.12);border-radius:5px;padding:22px 24px;color:#eef1f4">
          <div style="font:700 12px 'Space Mono',monospace;color:#3778c2;letter-spacing:.16em">NETFANG</div>
          <div style="font:800 22px 'Archivo',sans-serif;margin-top:6px">{email}</div>
        </a>
        <div style="background:#1b1f24;border:1px solid rgba(238,241,244,.12);border-radius:5px;padding:22px 24px">
          <div style="font:700 12px 'Space Mono',monospace;color:#3778c2;letter-spacing:.16em">HEIMILISFANG</div>
          <div style="font:800 20px 'Archivo',sans-serif;margin-top:6px">{address}</div>
          <a href={facebook} target="_blank" rel="noopener" style="display:inline-block;margin-top:12px;font:600 15px 'IBM Plex Sans',sans-serif">
            Facebook · /thsverk →
          </a>
        </div>
        <div data-reveal style="height:220px;border-radius:5px;overflow:hidden;border:1px solid rgba(238,241,244,.12)">
          <iframe title="Kort" src={mapEmbed(address)} style="width:100%;height:100%;border:0;filter:grayscale(.3)"></iframe>
        </div>
      </div>
    </div>
  </div>
</Base>
